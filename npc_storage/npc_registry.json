    {
      "id": "7701d4fb",
      "name": "哈罗德·铁橡",
      "npc_type": "permanent",
      "status": "active",
      "origin": "world_generation",
      "origin_event_id": null,
      "created_at": "2026-02-02T02:36:41.735646",
      "location": "镇公所",
      "profession": "镇长/治安官",
      "traits": [
        "务实",
        "谨慎",
        "固执",
        "责任感极强"
      ],
      "background": "哈罗德是银溪镇第三代镇民，他的祖父是首批拓荒者之一。他年轻时曾作为商队护卫往返于山区与平原，见识过外界的动荡与危险。三十年前回到故乡，因沉稳可靠被推举为治安官，十五年前兼任镇长。他坚信秩序与传统是小镇安宁的基石，对近年流传的魔法传说抱有深深的疑虑，认为那会打破小镇两百年来赖以生存的平衡。他与铁匠铺的塞拉斯·铁砧是表亲，但两人因对待“古老事物”的态度不同而关系微妙。",
      "goals": [
        "确保秋季贸易集会的安全与秩序",
        "调查西森林小径近期异常的动物踪迹",
        "维持银溪镇在变化世界中的独立与稳定",
        "在自己退休前培养一位可靠的继任者"
      ],
