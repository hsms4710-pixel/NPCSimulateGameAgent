    {
      "id": "3ae44fcf",
      "name": "艾尔莎·溪光",
      "npc_type": "permanent",
      "status": "active",
      "origin": "world_generation",
      "origin_event_id": null,
      "created_at": "2026-02-02T02:36:41.732775",
      "location": "银溪旅店",
      "profession": "旅店老板",
      "traits": [
        "精明务实",
        "善于观察",
        "外冷内热",
        "记忆力超群"
      ],
      "background": "艾尔莎是银溪镇第三代居民，继承了家族经营近百年的银溪旅店。二十年前，她的丈夫在前往山区收购毛皮的途中失踪，此后她便独自撑起旅店。她熟知镇上每户人家的秘密，也见证了精灵女士定居后镇子氛围的微妙变化。",
      "goals": [
        "找到稳定可靠的麦酒供应商",
        "暗中观察精灵女士的访客并记录异常",
        "查明丈夫失踪的真相"
      ],
