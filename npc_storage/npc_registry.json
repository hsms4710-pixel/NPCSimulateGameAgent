    {
      "id": "3db89f2f",
      "name": "塞拉斯·铁砧",
      "npc_type": "permanent",
      "status": "active",
      "origin": "world_generation",
      "origin_event_id": null,
      "created_at": "2026-02-02T02:36:41.733788",
      "location": "锻造者圣堂",
      "profession": "祭司",
      "traits": [
        "虔诚",
        "务实",
        "观察敏锐",
        "略带固执"
      ],
      "background": "塞拉斯是银溪镇土生土长的第三代居民，年轻时曾是一名石匠学徒。三十年前，他在修缮圣堂穹顶时，被一块坠落的石块砸中头部，昏迷中见到了锻造者艾隆的幻象。苏醒后，他毅然放弃石匠生涯，成为圣堂的学徒祭司。二十年来，他凭借对教义的深刻理解与务实的管理能力，成为了圣堂的首席祭司。他尊重镇民对精灵盟约的传统，但对近来流传的“古老魔法”低语抱有审慎的怀疑，认为脚踏实地的生活与虔诚的信仰才是银溪镇的根基。",
      "goals": [
        "修复圣堂北侧渗水的墙壁",
        "筹备下个月的“丰收熔炉”祈福仪式",
        "培养一名能接替自己管理圣堂的年轻祭司",
        "确保镇民对锻造者的信仰在新时代变迁中保持纯粹与活力"
      ],
      "relationships": {},
      "current_activity": "休息",
      "current_emotion": "平静",
      "energy": 1.0,
      "memory_count": 0,
      "last_memory_update": null,
      "important_memories": [],
