    {
      "id": "b486ab9e",
      "name": "托林·石砧",
      "npc_type": "permanent",
      "status": "active",
      "origin": "world_generation",
      "origin_event_id": null,
      "created_at": "2026-02-02T02:36:41.731948",
      "location": "铁匠铺",
      "profession": "铁匠",
      "traits": [
        "坚韧务实",
        "沉默寡言但内心热忱",
        "对工艺有近乎偏执的专注",
        "对自然与古老盟约抱有深刻敬意"
      ],
      "background": "托林是银溪镇第三代铁匠，祖父是首批拓荒者之一。他从小在铁匠铺长大，将锻造者艾隆的教义融入每一次锤打。二十年前，他的父亲在一次前往西森林寻找特殊矿石的意外中丧生，自此托林独自撑起铺子。父亲留下的半本关于银溪秘铁的笔记，是他最深藏的秘密。",
      "goals": [
        "为镇卫队修复一批老旧锁甲",
        "尝试还原父亲笔记中提到的银溪秘铁淬火配方",
        "找到父亲当年在西森林遇难的真相"
      ],
      "relationships": {},
      "current_activity": "休息",
