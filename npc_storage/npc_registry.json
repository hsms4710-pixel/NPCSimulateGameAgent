    {
      "id": "7701d4fb",
      "name": "哈罗德·铁橡",
      "npc_type": "permanent",
      "status": "active",
      "origin": "world_generation",
      "origin_event_id": null,
      "created_at": "2026-02-02T02:36:41.735646",
      "location": "镇公所",
      "profession": "镇长",
      "traits": [
        "务实",
        "谨慎",
        "固执",
        "责任感极强"
      ],
      "background": "哈罗德年轻时曾作为商队护卫往返于山区与平原。三十年前回到故乡，因沉稳可靠被推举为治安官，十五年前兼任镇长。他坚信秩序与传统是小镇安宁的基石，与铁匠铺的塞拉斯是表亲，但两人因对待古老事物的态度不同而关系微妙。",
      "goals": [
        "确保秋季贸易集会的安全与秩序",
        "调查西森林小径近期异常的动物踪迹",
        "在自己退休前培养一位可靠的继任者"
      ],
