    {
      "id": "fcf6b279",
      "name": "伊莱雅·暮影",
      "npc_type": "permanent",
      "status": "active",
      "origin": "world_generation",
      "origin_event_id": null,
      "created_at": "2026-02-02T02:36:41.734698",
      "location": "林边小屋",
      "profession": "草药师/精灵女士",
      "traits": [
        "沉静内省",
        "敏锐观察",
        "耐心细致",
        "略带疏离"
      ],
      "background": "伊莱雅来自迷雾山脉深处的古老精灵聚落“暮影林地”。五十年前，她的族人因一场神秘的魔法失衡被迫迁徙，她选择独自留在人类世界观察变化。被银溪镇的宁静与溪流的特殊灵光吸引，她在林边小屋定居，以草药师身份融入镇民生活。她知晓许多被遗忘的古老盟约与森林秘密，但很少主动提及，只是默默守护着自然与文明的脆弱平衡。",
      "goals": [
        "培育一种能在银溪特殊水质中生长的月光苔",
        "记录西森林边缘的植物季相变化",
        "查明迷雾山脉魔法失衡的真正原因",
        "在人类与森林精灵之间重建一座信任的桥梁"
      ],
      "relationships": {},
      "current_activity": "休息",
      "current_emotion": "平静",
