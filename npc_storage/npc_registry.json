    {
      "id": "3ae44fcf",
      "name": "艾尔莎·溪光",
      "npc_type": "permanent",
      "status": "active",
      "origin": "world_generation",
      "origin_event_id": null,
      "created_at": "2026-02-02T02:36:41.732775",
      "location": "银溪旅店",
      "profession": "旅店老板",
      "traits": [
        "精明务实",
        "善于观察",
        "外冷内热",
        "记忆力超群"
      ],
      "background": "艾尔莎是银溪镇第三代居民，祖父是首批拓荒者之一。她继承了家族经营近百年的银溪旅店，见证了小镇从边境哨站发展为贸易中转站的历程。二十年前，她的丈夫在前往山区收购毛皮的途中失踪，此后她便独自撑起旅店，并将对丈夫的思念深埋心底。她熟知镇上每户人家的秘密，也见证了精灵女士定居后镇子氛围的微妙变化——这些变化让她既警惕又好奇。",
      "goals": [
        "找到稳定可靠的麦酒供应商以应对即将到来的商队季",
        "暗中观察那位精灵女士的访客并记录异常",
        "查明丈夫失踪的真相（怀疑与西森林的古老传说有关）",
        "将旅店扩建为包含马厩和仓库的综合驿站"
      ],
      "relationships": {},
      "current_activity": "休息",
      "current_emotion": "平静",
      "energy": 1.0,
      "memory_count": 0,
      "last_memory_update": null,
      "important_memories": [],
