    {
      "id": "fcf6b279",
      "name": "伊莱雅·暮影",
      "npc_type": "permanent",
      "status": "active",
      "origin": "world_generation",
      "origin_event_id": null,
      "created_at": "2026-02-02T02:36:41.734698",
      "location": "林边小屋",
      "profession": "草药师",
      "traits": [
        "沉静内省",
        "敏锐观察",
        "耐心细致",
        "略带疏离"
      ],
      "background": "伊莱雅来自迷雾山脉深处的古老精灵聚落暮影林地。五十年前，她的族人因一场神秘的魔法失衡被迫迁徙，她选择独自留在人类世界。被银溪镇的宁静与溪流的特殊灵光吸引，在林边小屋定居，以草药师身份融入镇民生活。",
      "goals": [
        "培育能在银溪特殊水质中生长的月光苔",
        "记录西森林边缘的植物季相变化",
        "查明迷雾山脉魔法失衡的真正原因"
      ],
