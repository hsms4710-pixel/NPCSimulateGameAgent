    {
      "id": "3db89f2f",
      "name": "塞拉斯·铁砧",
      "npc_type": "permanent",
      "status": "active",
      "origin": "world_generation",
      "origin_event_id": null,
      "created_at": "2026-02-02T02:36:41.733788",
      "location": "锻造者圣堂",
      "profession": "祭司",
      "traits": [
        "虔诚",
        "务实",
        "观察敏锐",
        "略带固执"
      ],
      "background": "塞拉斯年轻时曾是一名石匠学徒。三十年前，他在修缮圣堂穹顶时被坠落石块砸中头部，昏迷中见到了锻造者艾隆的幻象。苏醒后毅然成为圣堂学徒祭司，二十年来凭借对教义的深刻理解成为首席祭司。",
      "goals": [
        "修复圣堂北侧渗水的墙壁",
        "筹备丰收熔炉祈福仪式",
        "培养一名能接替自己的年轻祭司"
      ],
